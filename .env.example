# App
NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGIN=http://localhost:4317

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nyumba
DB_PASSWORD=nyumba
DB_NAME=nyumba
DB_LOGGING=false

# Auth (Sprint 2)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# Auth tuning (Sprint 2)
APP_URL=http://localhost:4317
BCRYPT_ROUNDS=12
REFRESH_TTL_DAYS=7
INVITE_TTL_MINUTES=10080
RESET_TTL_MINUTES=60

# Adminer (docker compose --profile tools up -d adminer)
# `db` = the compose Postgres; use `host.docker.internal` for a host-installed one.
ADMINER_TARGET=db
ADMINER_PORT=8080
